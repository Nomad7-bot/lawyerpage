# ============================================================
# Public (클라이언트 번들에 포함됨 — 민감 정보 절대 금지)
# ============================================================

# Supabase 프로젝트 공용 정보
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 사이트 URL (OG, canonical, redirect 기준)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Server-only (서버 전용 — 절대 클라이언트에 노출 금지)
# ============================================================

# Supabase Service Role Key
# Supabase Dashboard → Settings → API → service_role (⚠️ secret)
# 사용처: scripts/create-admin.ts 등 서버 스크립트 전용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 초기 관리자 계정 비밀번호 (scripts/create-admin.ts 실행 시 사용)
# 최소 10자 이상, 영문+숫자+특수문자 조합 권장
INITIAL_ADMIN_PASSWORD=change-this-before-running

# Resend 이메일 API Key (Phase 2 예약 알림용)
RESEND_API_KEY=your-resend-api-key
